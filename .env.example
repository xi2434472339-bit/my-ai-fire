# CloudBase 配置（复制为 .env 并填入真实值）
# 获取方式见 README.md 云端同步配置

# 应用环境：development（本地开发）| production（正式部署）
VITE_APP_ENV=development

# 是否启用云端同步：true | false
# 正式环境设置为 true，本地开发设置为 false
VITE_ENABLE_CLOUD_SYNC=false

# CloudBase 环境 ID（正式部署时填入）
VITE_TCB_ENV_ID=

# 共享台账 ID（所有协作者必须相同）
VITE_LEDGER_ID=sales-ledger-main

# 访问密码（留空则不启用密码保护）
# 所有协作者使用同一个密码访问台账
VITE_ACCESS_PASSWORD=
